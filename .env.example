APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_TIMEZONE=Africa/Lusaka

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug
LOG_DAILY_DAYS=30

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=zaqa_portal
DB_USERNAME=root
DB_PASSWORD=
DB_TIMEZONE=+02:00

SESSION_DRIVER=database
SESSION_LIFETIME=15

ZAQA_UPLOAD_MAX_FILE_SIZE_MB=3
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"
BANK_TRANSFER_POP_NOTIFICATION_EMAILS=finance@example.com
BANK_TRANSFER_POP_EMAIL_ATTACHMENT_MAX_BYTES=5242880
BANK_TRANSFER_BANK_NAME="Zambia National Commercial Bank Plc"
BANK_TRANSFER_ACCOUNT_NAME="Zambia Qualifications Authority"
BANK_TRANSFER_ACCOUNT_NUMBER=
BANK_TRANSFER_BRANCH_CODE=
CERTIFICATE_VERIFICATION_BASE_URL=http://localhost/certificates
CERTIFICATE_COAT_OF_ARMS_PATH=resources/images/certificates/coat_of_arms_watermark.png
CERTIFICATE_WATERMARK_ENABLED=true

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Applicant registration contact methods (both enabled by default)
REGISTER_WITH_EMAIL=true
REGISTER_WITH_SMS=true

# Outbound notifications (email + SMS listeners)
NOTIFICATIONS_MAIL_QUEUE=notifications
# Leave empty to use the default queue for SMS jobs
NOTIFICATIONS_SMS_QUEUE=
NOTIFICATIONS_LISTENER_QUEUE=default
SMS_ENABLED=false
SMS_PROVIDER=log
SMS_FROM=ZAQA
SMS_MAX_LENGTH=159
SMS_LOW_BALANCE_THRESHOLD=100
SMS_CRITICAL_BALANCE_THRESHOLD=10
SMS_ALERT_EMAILS=
ZAMTEL_SMS_BASE_URL=https://bulksms.zamtel.co.zm
ZAMTEL_SMS_API_KEY=
ZAMTEL_SMS_SENDER_ID=ZAQA
ZAMTEL_SMS_TIMEOUT=30
ZAMTEL_SMS_CONNECT_TIMEOUT=10
ZAMTEL_SMS_VERIFY_SSL=true

# cGrate (Konik) Mobile Money Payments
CGRATE_ENABLED=false
CGRATE_BASE_URL=https://test.543.cgrate.co.zm
CGRATE_USERNAME=
CGRATE_PASSWORD=
CGRATE_TIMEOUT=30
CGRATE_CONNECT_TIMEOUT=10
CGRATE_VERIFY_SSL=true
CGRATE_POLL_INTERVAL_SECONDS=10
CGRATE_MAX_QUERY_ATTEMPTS=30
CGRATE_PAYMENT_EXPIRY_MINUTES=10
CGRATE_DEFAULT_CURRENCY=ZMW
CGRATE_AMOUNT_MODE=kwacha_decimal
CGRATE_MSISDN_FORMAT=local
CGRATE_UNKNOWN_FAIL_AFTER_ATTEMPTS=5
CGRATE_ENDPOINT_PATH=/Konik/KonikWs
CGRATE_SOAP_NAMESPACE=http://konik.cgrate.com
CGRATE_CONTENT_TYPE="application/soap+xml; charset=utf-8"
CGRATE_ALLOW_TEST_COMMAND_IN_PRODUCTION=false
CGRATE_CALLBACK_ENABLED=false
CGRATE_CALLBACK_TOKEN=
CGRATE_CALLBACK_ALLOWED_IPS=

# Payment queues (Redis recommended in production)
QUEUE_CONNECTION=database
PAYMENTS_QUEUE_HIGH=payments-high
PAYMENTS_QUEUE=payments

# Auto-verification (foundation)
AUTO_VERIFICATION_ENABLED=true
AUTO_VERIFICATION_THRESHOLD=70
AUTO_VERIFICATION_AUTO_ISSUE_ENABLED=false

# ---------------------------------------------------------------------------
# Institution pull integrations
# Production: configure each institution in Admin → Integrations →
# Institution Pull Integrations (lookup URL, bearer token, etc.).
# ZAQA does NOT use .env for per-institution lookup URLs or tokens.
#
# Optional LOCAL DEVELOPMENT ONLY — seeds University of Zambia integration
# when running db:seed. Leave unset in production/staging.
# UNZA_SIS_LOOKUP_URL=http://127.0.0.1:8001/api/zaqa/v1/learner-lookup
# UNZA_SIS_LOOKUP_TOKEN=
# ---------------------------------------------------------------------------
