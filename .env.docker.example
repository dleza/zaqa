APP_NAME="ZAQA Portal (Docker)"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080
APP_TIMEZONE=Africa/Lusaka

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=zaqa_portal
DB_USERNAME=zaqa
DB_PASSWORD=zaqa_password
DB_TIMEZONE=+02:00

SESSION_DRIVER=database
QUEUE_CONNECTION=database
CACHE_STORE=database
FILESYSTEM_DISK=local

# If you run the optional MySQL port mapping in docker-compose.yml, you can connect from host:
# DB_HOST=127.0.0.1

VITE_APP_NAME="${APP_NAME}"

# Optional: keep Redis disabled unless you add a redis service + PHP extension.
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# cGrate / auto-verification envs can be copied from .env.example as needed.
